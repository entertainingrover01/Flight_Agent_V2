# Environment configuration template
# Copy to .env and fill in your values

# Gemini API Key
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-pro

# Google OAuth for direct Gmail integration
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8001/api/gmail/callback

# Backend configuration  
BACKEND_PORT=8001
BACKEND_HOST=localhost

# Frontend configuration
FRONTEND_URL=http://localhost:8000

# Optional: External APIs
# Free tier option via API.Market:
# AERODATABOX_APIMARKET_KEY=your_key
#
# Alternative marketplace via RapidAPI:
# AERODATABOX_RAPIDAPI_KEY=your_key
# AERODATABOX_RAPIDAPI_HOST=aerodatabox.p.rapidapi.com
#
# Older paid option:
# AVIATIONSTACK_API_KEY=your_key
# OPENWEATHERMAP_API_KEY=your_key
# NOAA_API_KEY=your_key
